
plugins {
    id 'nf-amazon@2.3.0'
}

aws {
    accessKey = System.getenv('NF_AWS_ACCESS_KEY')
    secretKey = System.getenv('NF_AWS_SECRET_KEY')
    region    = 'eu-central-1'
    client {
        endpoint         = 'https://a3s.fi'
        s3PathStyleAccess = true
        signerVersion    = 'AWSS3V4SignerType'
        connectionTimeout = 10000
    }
}

nextflow.enable.strict = false 
cleanup                = false
report.overwrite       = true
timeline.overwrite     = true

workflow.onComplete = {
    workDir.resolve("stage-${workflow.sessionId}").deleteDir()
}


process {

  executor  = 'local'
  scratch   = false

  errorStrategy = 'ignore'
  
  withName: BWA_INDEX {
    cpus     = 24      
    memory   = '45 GB'
  }
  withName: ALIGN_BWA {
    cpus     = 10
    memory   = '20 GB'
  }
  withName: REALIGN_INDELS {
    cpus     = 2
    memory   = '4 GB'
  }
  withName: MERGE_BAMS {
    cpus     = 1
  }
  withName: RUN_HAPLOTYPECALLER {
    cpus     = 2
    memory   = '4 GB'
  }
  withName: MERGE_GVCFS {
    cpus     = 1
  }
  withName: CONVERT_CRAM_AND_PUBLISH {
    cpus     = 2
  }
  withName: PUBLISH_GVCF_VCF {
    cpus     = 1
  }
  withName: ALIGN_MINIMAP2 {
    cpus     = 10
    memory   = '20 GB'
  }
  withName: RUN_DEEPVARIANT {
    cpus     = 60
    memory   = '100 GB'
  }
  withName: PUBLISH_GVCF {
    cpus     = 1
  }
  withName: CONVERT_BAM {
    cpus     = 2
  }
} 
